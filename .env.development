# Asset Loading Configuration
# Use ./src/assets for local/direct use (bun production or bun development)
ASSETS_PATH=../../src/assets

# Asset Server Configuration
WEBSRV_PORT=8000
WEBSRV_PORTSSL=8082
WEBSRV_USESSL=false
WEBSRV_CERT_PATH=./src/certs/cert.pem
WEBSRV_KEY_PATH=./src/certs/key.pem
WEBSRV_CA_PATH=./src/certs/cert.ca-bundle

# CORS Configuration (Comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1,http://frostfire-assets-dev:8000,http://localhost:8000,http://127.0.0.1:8000,http://frostfire-gateway-dev:9999,http://frostfire-forge-dev:3000

# Authentication
ASSET_SERVER_AUTH_KEY="frostfire_forge_development"